{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Voxium",
  "version": "1.7.3",
  "identifier": "com.voxium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "title": "Voxium",
        "url": "splash.html",
        "width": 360,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": true,
        "backgroundColor": "#1a1a2e"
      },
      {
        "label": "main",
        "title": "Voxium",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false,
        "backgroundColor": "#1a1a2e"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' http://localhost:3001 ws://localhost:3001 https://voxium.app https://*.voxium.app wss://voxium.app wss://*.voxium.app; img-src 'self' blob: data: http://localhost:3001 https://voxium.app https://*.voxium.app; style-src 'self' 'unsafe-inline'; media-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Aizen93/voxium/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFQTNFMkE0Mzc3NkRGMTUKUldRVjMzWTNwT0tqdnVLbW5HaHJwalhESGE1TFNtTndIbnRSUDNhbUtaejlLQm5LbzhkRERGYXMK"
    }
  }
}
