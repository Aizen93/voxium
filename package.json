{
  "name": "voxium",
  "version": "1.7.3",
  "private": true,
  "description": "Voxium - Modern voice & text communication platform",
  "scripts": {
    "dev:server": "pnpm --filter @voxium/server dev",
    "dev:desktop": "pnpm --filter @voxium/desktop dev",
    "dev:admin": "pnpm --filter @voxium/admin dev",
    "dev": "pnpm run dev:server & pnpm run dev:desktop",
    "build:shared": "pnpm --filter @voxium/shared build",
    "build:server": "pnpm --filter @voxium/server build",
    "build:desktop": "pnpm --filter @voxium/desktop build",
    "build:admin": "pnpm --filter @voxium/admin build",
    "build": "pnpm run build:shared && pnpm run build:server & pnpm run build:desktop",
    "typecheck": "pnpm run build:shared && pnpm --filter @voxium/server exec tsc --noEmit && pnpm --filter @voxium/desktop exec tsc --noEmit && pnpm --filter @voxium/admin exec tsc --noEmit",
    "lint": "pnpm run --parallel -r lint",
    "db:migrate": "pnpm --filter @voxium/server db:migrate",
    "db:seed": "pnpm --filter @voxium/server db:seed",
    "db:studio": "pnpm --filter @voxium/server db:studio",
    "test": "pnpm --filter @voxium/server test && pnpm --filter @voxium/desktop test",
    "test:watch": "pnpm --filter @voxium/server test:watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "mediasoup",
      "prisma"
    ],
    "overrides": {
      "rollup": ">=4.59.0",
      "fast-xml-parser": ">=5.5.7",
      "tar": ">=7.5.11",
      "flatted": ">=3.4.2",
      "socket.io-parser": ">=4.2.6"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@roamhq/wrtc": "^0.10.0",
    "eslint": "^10.0.3",
    "mediasoup-client": "^3.18.7",
    "otpauth": "^9.5.0",
    "redis": "^5.11.0",
    "typescript-eslint": "^8.57.1"
  }
}
